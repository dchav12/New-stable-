      "source": [
        "# ===== USER INPUTS (edit these) =====\n",
        "ODDS_API_KEY = \"10ceac94f9b9cb76f8c65510ca6df18f\"\n",
        "TZ_LOCAL = \"America/New_York\"          # Eastern Time\n",
        "SLATE_DATE_LOCAL = \"2026-04-20\"        # what you WANT to run (cell auto-switches if slate is actually next ET date)\n",
        "N_SIMS = 50000                         # per your request (can change anytime)\n",
        "\n",
        "# Manual unit bump (because exposure felt too small)\n",
        "UNIT_BUMP_MULT = 2.0                   # 2.0 = double units\n",
        "UNIT_MIN = 0.10                        # floor after bump (optional)\n",
        "UNIT_MAX = 1.00                        # cap\n",
        "\n",
        "# ===== PLAYOFF MODE =====\n",
        "PLAYOFF_MODE = True\n",
        "PLAYOFF_STAGE = \"play_in\"              # options: \"regular\", \"play_in\", \"playoffs\"\n",
        "\n",
        "# ===== OPTIONAL MANUAL INJURY OVERRIDES =====\n",
        "# Positive number = points ADDED to that team's expected margin (good for that team)\n",
        "# Negative number = points SUBTRACTED from that team's expected margin (bad for that team)\n",
        "# Example:\n",
        "# MANUAL_INJURY_OVERRIDES = {\n",
        "#     \"Los Angeles Lakers\": -3.5,\n",
        "#     \"Oklahoma City Thunder\": -1.0,\n",
        "# }\n",
        "MANUAL_INJURY_OVERRIDES = {}\n",
        "\n",
        "# ===== OPTIONAL RECENCY BLEND TOGGLE =====\n",
        "USE_RECENCY_BLEND = False              # if False, uses season standings only\n",
        "RECENCY_LAST_N = 10                    # reserved for future extension\n",
        "\n",
        "# =======================\n",
        "# IMPORTS\n",
        "# =======================\n",
        "import os\n",
        "import math\n",
        "import json\n",
        "import time\n",
        "import pytz\n",
        "import requests\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "from datetime import datetime\n",
        "\n",
        "# =======================\n",
        "# 1) HELPERS\n",
        "# =======================\n",
        "def _norm_team(s: str) -> str:\n",
        "    return (str(s).lower()\n",
        "            .replace(\" \", \"\")\n",
        "            .replace(\".\", \"\")\n",
        "            .replace(\"-\", \"\")\n",
        "            .replace(\"’\", \"\")\n",
        "            .replace(\"'\", \"\")\n",
        "            .replace(\"&\", \"and\"))\n",
        "\n",
        "ALIASES = {\n",
        "    \"la clippers\": \"los angeles clippers\",\n",
        "    \"losangelesclippers\": \"los angeles clippers\",\n",
        "    \"la lakers\": \"los angeles lakers\",\n",
        "    \"losangeleslakers\": \"los angeles lakers\",\n",
        "    \"ny knicks\": \"new york knicks\",\n",
        "    \"newyorkknicks\": \"new york knicks\",\n",
        "    \"okc thunder\": \"oklahoma city thunder\",\n",
        "    \"oklahomacitythunder\": \"oklahoma city thunder\",\n",
        "    \"utah jazz\": \"utah jazz\",\n",
        "    \"new orleans pelicans\": \"new orleans pelicans\",\n",
        "    \"san antonio spurs\": \"san antonio spurs\",\n",
        "    \"golden state warriors\": \"golden state warriors\",\n",
        "    \"portland trail blazers\": \"portland trail blazers\",\n",
        "    \"orlando magic\": \"orlando magic\",\n",
        "}\n",
        "\n",
        "def _canon_team_name(s: str) -> str:\n",
        "    s2 = str(s).strip().lower()\n",
        "    return ALIASES.get(s2, str(s).strip())\n",
        "\n",
        "def _to_amer(x):\n",
        "    x = float(x)\n",
        "    if 1.01 <= x <= 20.0:\n",
        "        return (x - 1) * 100 if x >= 2 else -100 / (x - 1)\n",
        "    return x\n",
        "\n",
        "def _imp_prob_amer(a):\n",
        "    a = _to_amer(a)\n",
        "    return (abs(a) / (abs(a) + 100.0)) if a < 0 else (100.0 / (a + 100.0))\n",
        "\n",
        "def _amer_from_prob(p):\n",
        "    p = float(p)\n",
        "    if p <= 0:\n",
        "        return np.nan\n",
        "    if p >= 1:\n",
        "        return -10000.0\n",
        "    return (-100.0 * p / (1 - p)) if p >= 0.5 else (100.0 * (1 - p) / p)\n",
        "\n",
        "def _fmt_odds(a):\n",
        "    a = float(a)\n",
        "    return f\"+{int(round(a))}\" if a > 0 else f\"{int(round(a))}\"\n",
        "\n",
        "def _fmt_spread(x):\n",
        "    x = float(x)\n",
        "    return f\"+{x:g}\" if x > 0 else f\"{x:g}\"\n",
        "\n",
        "def _kelly_half(p, amer):\n",
        "    a = _to_amer(amer)\n",
        "    b = (a / 100.0) if a > 0 else (100.0 / abs(a))\n",
        "    q = 1.0 - p\n",
        "    f = (b * p - q) / b\n",
        "    return max(0.0, 0.5 * f)\n",
        "\n",
        "def _units_from_halfkelly(f_half):\n",
        "    # slightly more aggressive scaling for playoff edges\n",
        "    return float(np.clip(f_half/0.22, 0.0, 1.0))\n",
        "\n",
        "def _safe_float(x):\n",
        "    try:\n",
        "        return float(x)\n",
        "    except Exception:\n",
        "        return np.nan\n",
        "\n",
        "def _median_or_nan(vals):\n",
        "    vals = [float(v) for v in vals if v is not None and not pd.isna(v)]\n",
        "    return float(np.median(vals)) if vals else np.nan\n",
        "\n",
        "def _discord(df, header):\n",
        "    out = [header, \"\"]\n",
        "    for _, r in df.iterrows():\n",
        "        out.append(r[\"matchup\"])\n",
        "        out.append(f\"{r['market']}: {r['bet']} ({_fmt_odds(r['odds'])}) — {r['units']:.2f}u\")\n",
        "        out.append(\n",
        "            f\"Model%: {100*r['model_prob']:.1f}% | Edge: {100*r['edge']:.1f}% | Fair: {_fmt_odds(r['fair_odds'])}\"\n",
        "        )\n",
        "        out.append(\"\")\n",
        "    return \"\\n\".join(out).strip()\n",
        "\n",
        "# =======================\n",
        "# 2) PLAYOFF SETTINGS\n",
        "# =======================\n",
        "HOME_COURT_PTS = 2.0\n",
        "W_OFF = 0.55\n",
        "W_DEF = 0.45\n",
        "\n",
        "if not PLAYOFF_MODE or PLAYOFF_STAGE == \"regular\":\n",
        "    PACE_MULT = 1.00\n",
        "    ANCHOR_MARGIN_W = 0.45\n",
        "    ANCHOR_TOTAL_W = 0.45\n",
        "    BASE_MARGIN_SD = 14.2\n",
        "    BASE_TOTAL_SD = 18.5\n",
        "elif PLAYOFF_STAGE == \"play_in\":\n",
        "    PACE_MULT = 0.97\n",
        "    ANCHOR_MARGIN_W = 0.52\n",
        "    ANCHOR_TOTAL_W = 0.50\n",
        "    BASE_MARGIN_SD = 12.6\n",
        "    BASE_TOTAL_SD = 16.5\n",
        "elif PLAYOFF_STAGE == \"playoffs\":\n",
        "    PACE_MULT = 0.95\n",
        "    ANCHOR_MARGIN_W = 0.62\n",
        "    ANCHOR_TOTAL_W = 0.58\n",
        "    BASE_MARGIN_SD = 11.8\n",
        "    BASE_TOTAL_SD = 15.8\n",
        "else:\n",
        "    raise ValueError(f\"Invalid PLAYOFF_STAGE: {PLAYOFF_STAGE}\")\n",
        "\n",
        "# =======================\n",
        "# 3) CONSENSUS ODDS API PULL\n",
        "# =======================\n",
        "SPORT = \"basketball_nba\"\n",
        "REGIONS = \"us\"\n",
        "MARKETS = \"h2h,spreads,totals\"\n",
        "ODDS_FORMAT = \"american\"\n",
        "DATE_FORMAT = \"iso\"\n",
        "\n",
        "url = f\"https://api.the-odds-api.com/v4/sports/{SPORT}/odds/\"\n",
        "params = {\n",
        "    \"apiKey\": ODDS_API_KEY,\n",
        "    \"regions\": REGIONS,\n",
        "    \"markets\": MARKETS,\n",
        "    \"oddsFormat\": ODDS_FORMAT,\n",
        "    \"dateFormat\": DATE_FORMAT,\n",
        "}\n",
        "\n",
        "resp = requests.get(url, params=params, timeout=40)\n",
        "resp.raise_for_status()\n",
        "js = resp.json()\n",
        "\n",
        "rows = []\n",
        "for ev in js:\n",
        "    home = ev.get(\"home_team\")\n",
        "    away = ev.get(\"away_team\")\n",
        "    commence = ev.get(\"commence_time\")\n",
        "\n",
        "    home_spread_points = []\n",
        "    home_spread_prices = []\n",
        "\n",
        "    total_over_points = []\n",
        "    total_over_prices = []\n",
        "\n",
        "    home_ml_prices = []\n",
        "    away_ml_prices = []\n",
        "\n",
        "    for bm in ev.get(\"bookmakers\", []):\n",
        "        for m in bm.get(\"markets\", []):\n",
        "            key = m.get(\"key\")\n",
        "            outcomes = m.get(\"outcomes\", [])\n",
        "\n",
        "            if key == \"spreads\":\n",
        "                for o in outcomes:\n",
        "                    if o.get(\"name\") == home:\n",
        "                        if o.get(\"point\") is not None:\n",
        "                            home_spread_points.append(_safe_float(o.get(\"point\")))\n",
        "                        if o.get(\"price\") is not None:\n",
        "                            home_spread_prices.append(_safe_float(o.get(\"price\")))\n",
        "\n",
        "            elif key == \"totals\":\n",
        "                for o in outcomes:\n",
        "                    if o.get(\"name\") == \"Over\":\n",
        "                        if o.get(\"point\") is not None:\n",
        "                            total_over_points.append(_safe_float(o.get(\"point\")))\n",
        "                        if o.get(\"price\") is not None:\n",
        "                            total_over_prices.append(_safe_float(o.get(\"price\")))\n",
        "\n",
        "            elif key == \"h2h\":\n",
        "                for o in outcomes:\n",
        "                    if o.get(\"name\") == home and o.get(\"price\") is not None:\n",
        "                        home_ml_prices.append(_safe_float(o.get(\"price\")))\n",
        "                    elif o.get(\"name\") == away and o.get(\"price\") is not None:\n",
        "                        away_ml_prices.append(_safe_float(o.get(\"price\")))\n",
        "\n",
        "    row = {\n",
        "        \"home_team\": home,\n",
        "        \"away_team\": away,\n",
        "        \"commence_time\": commence,\n",
        "        \"home_spread\": _median_or_nan(home_spread_points),\n",
        "        \"home_spread_price\": _median_or_nan(home_spread_prices),\n",
        "        \"total_line\": _median_or_nan(total_over_points),\n",
        "        \"total_price_used\": _median_or_nan(total_over_prices),\n",
        "        \"home_ml_price\": _median_or_nan(home_ml_prices),\n",
        "        \"away_ml_price\": _median_or_nan(away_ml_prices),\n",
        "        \"n_books_spread\": len(home_spread_points),\n",
        "        \"n_books_total\": len(total_over_points),\n",
        "        \"n_books_ml\": min(len(home_ml_prices), len(away_ml_prices)),\n",
        "    }\n",
        "    rows.append(row)\n",
        "\n",
        "market_df = pd.DataFrame(rows)\n",
        "market_df.to_csv(\"market_snapshot_latest.csv\", index=False)\n",
        "print(f\"✔ Odds API pull complete. market_df rows={len(market_df)} | saved market_snapshot_latest.csv\")\n",
        "\n",
        "# Parse times -> ET local date\n",
        "tz_local = pytz.timezone(TZ_LOCAL)\n",
        "market_df[\"commence_time_utc\"] = pd.to_datetime(market_df[\"commence_time\"], utc=True, errors=\"coerce\")\n",
        "if market_df[\"commence_time_utc\"].isna().all():\n",
        "    raise RuntimeError(\"All commence_time values failed to parse.\")\n",
        "\n",
        "market_df[\"commence_time_local\"] = market_df[\"commence_time_utc\"].dt.tz_convert(tz_local)\n",
        "market_df[\"slate_date_local\"] = market_df[\"commence_time_local\"].dt.strftime(\"%Y-%m-%d\")\n",
        "print(\"[DEBUG] ET dates present in market snapshot:\", sorted(market_df[\"slate_date_local\"].dropna().unique().tolist()))\n",
        "\n",
        "req = str(SLATE_DATE_LOCAL)\n",
        "games_df = market_df[market_df[\"slate_date_local\"] == req].copy()\n",
        "\n",
        "if len(games_df) == 0:\n",
        "    valid_dates = sorted(market_df[\"slate_date_local\"].dropna().unique().tolist())\n",
        "    if not valid_dates:\n",
        "        raise RuntimeError(\"No valid ET dates found in market snapshot.\")\n",
        "    fallback = valid_dates[0]\n",
        "    print(f\"⚠️ No games for requested date. Auto-switching SLATE_DATE_LOCAL -> {fallback}\")\n",
        "    SLATE_DATE_LOCAL = fallback\n",
        "    games_df = market_df[market_df[\"slate_date_local\"] == fallback].copy()\n",
        "\n",
        "games_df = games_df.reset_index(drop=True)\n",
        "print(f\"✔ Slate filter applied (ET): {SLATE_DATE_LOCAL} | rows={len(games_df)}\")\n",
        "\n",
        "# Guardrails\n",
        "required_market_cols = [\"home_spread\", \"home_spread_price\", \"total_line\", \"total_price_used\", \"home_ml_price\", \"away_ml_price\"]\n",
        "missing_summary = {c: int(games_df[c].isna().sum()) for c in required_market_cols}\n",
        "print(\"Market null counts:\", missing_summary)\n",
        "\n",
        "# =======================\n",
        "# 4) TEAM STATS PULL — ESPN STANDINGS\n",
        "# =======================\n",
        "stand_url = \"https://site.web.api.espn.com/apis/v2/sports/basketball/nba/standings\"\n",
        "resp = requests.get(stand_url, timeout=40)\n",
        "resp.raise_for_status()\n",
        "sj = resp.json()\n",
        "\n",
        "entries_lists = []\n",
        "def _collect_entries(obj):\n",
        "    if isinstance(obj, dict):\n",
        "        for k, v in obj.items():\n",
        "            if k == \"entries\" and isinstance(v, list):\n",
        "                entries_lists.append(v)\n",
        "            else:\n",
        "                _collect_entries(v)\n",
        "    elif isinstance(obj, list):\n",
        "        for it in obj:\n",
        "            _collect_entries(it)\n",
        "\n",
        "_collect_entries(sj)\n",
        "entries = []\n",
        "for lst in entries_lists:\n",
        "    entries.extend(lst)\n",
        "\n",
        "def _stats_map(stats_list):\n",
        "    m = {}\n",
        "    if not isinstance(stats_list, list):\n",
        "        return m\n",
        "    for s in stats_list:\n",
        "        if not isinstance(s, dict):\n",
        "            continue\n",
        "        nm = str(s.get(\"name\") or \"\").strip().lower()\n",
        "        ab = str(s.get(\"abbr\") or \"\").strip().lower()\n",
        "        val = s.get(\"value\", None)\n",
        "        if nm:\n",
        "            m[nm] = val\n",
        "        if ab:\n",
        "            m[ab] = val\n",
        "    return m\n",
        "\n",
        "def _pick_by_substring(m, candidates):\n",
        "    for sub in candidates:\n",
        "        sub = sub.lower()\n",
        "        for k, v in m.items():\n",
        "            if sub in k:\n",
        "                try:\n",
        "                    if v is None:\n",
        "                        continue\n",
        "                    return float(v)\n",
        "                except Exception:\n",
        "                    continue\n",
        "    return None\n",
        "\n",
        "rows = []\n",
        "seen = set()\n",
        "\n",
        "for e in entries:\n",
        "    if not isinstance(e, dict):\n",
        "        continue\n",
        "    team_obj = e.get(\"team\") or {}\n",
        "    team = team_obj.get(\"displayName\") or team_obj.get(\"name\")\n",
        "    if not team or team in seen:\n",
        "        continue\n",
        "    seen.add(team)\n",
        "\n",
        "    sm = _stats_map(e.get(\"stats\", []))\n",
        "    gp = _pick_by_substring(sm, [\"gamesplayed\", \"games played\", \"gp\", \"games\"])\n",
        "    pf = _pick_by_substring(sm, [\"pointsfor\", \"points for\", \"pf\"])\n",
        "    pa = _pick_by_substring(sm, [\"pointsagainst\", \"points against\", \"pa\"])\n",
        "\n",
        "    ppg = oppg = None\n",
        "    if pf is not None and pa is not None:\n",
        "        if pf > 200 or pa > 200:\n",
        "            if gp is not None and gp > 0:\n",
        "                ppg = pf / gp\n",
        "                oppg = pa / gp\n",
        "        else:\n",
        "            ppg = pf\n",
        "            oppg = pa\n",
        "\n",
        "    rows.append({\n",
        "        \"team\": team,\n",
        "        \"ppg\": ppg,\n",
        "        \"oppg\": oppg,\n",
        "        \"gp\": gp,\n",
        "        \"pf\": pf,\n",
        "        \"pa\": pa,\n",
        "    })\n",
        "\n",
        "team_stats = pd.DataFrame(rows)\n",
        "team_stats[\"ppg\"] = pd.to_numeric(team_stats[\"ppg\"], errors=\"coerce\")\n",
        "team_stats[\"oppg\"] = pd.to_numeric(team_stats[\"oppg\"], errors=\"coerce\")\n",
        "team_stats = team_stats.dropna(subset=[\"ppg\", \"oppg\"]).reset_index(drop=True)\n",
        "\n",
        "if len(team_stats) < 25:\n",
        "    raise RuntimeError(f\"ESPN standings parse too small: rows={len(team_stats)}\")\n",
        "\n",
        "med = float(pd.concat([team_stats[\"ppg\"], team_stats[\"oppg\"]], ignore_index=True).median())\n",
        "if med > 200:\n",
        "    raise RuntimeError(f\"PPG scale failed: median={med:.1f}. Looks like totals instead of per-game stats.\")\n",
        "\n",
        "team_stats = team_stats[[\"team\", \"ppg\", \"oppg\"]].copy()\n",
        "print(f\"✔ team_stats built from ESPN standings. rows={len(team_stats)} | median={med:.1f}\")\n",
        "display(team_stats.sort_values(\"team\").head(12))\n",
        "\n",
        "# =======================\n",
        "# 5) TEAM STATS MERGE\n",
        "# =======================\n",
        "def merge_team_stats(games_df: pd.DataFrame, team_stats: pd.DataFrame) -> pd.DataFrame:\n",
        "    g = games_df.copy()\n",
        "    ts = team_stats.copy()\n",
        "\n",
        "    g[\"home_team_clean\"] = g[\"home_team\"].map(_canon_team_name)\n",
        "    g[\"away_team_clean\"] = g[\"away_team\"].map(_canon_team_name)\n",
        "    ts[\"team_clean\"] = ts[\"team\"].map(_canon_team_name)\n",
        "\n",
        "    g[\"home_team_norm\"] = g[\"home_team_clean\"].map(_norm_team)\n",
        "    g[\"away_team_norm\"] = g[\"away_team_clean\"].map(_norm_team)\n",
        "    ts[\"team_norm\"] = ts[\"team_clean\"].map(_norm_team)\n",
        "\n",
        "    ts = ts.sort_values(\"team_clean\").drop_duplicates(subset=[\"team_norm\"], keep=\"last\").reset_index(drop=True)\n",
        "\n",
        "    home_merge = ts[[\"team_norm\", \"ppg\", \"oppg\"]].rename(columns={\n",
        "        \"team_norm\": \"home_team_norm\",\n",
        "        \"ppg\": \"home_ppg\",\n",
        "        \"oppg\": \"home_oppg\",\n",
        "    })\n",
        "    away_merge = ts[[\"team_norm\", \"ppg\", \"oppg\"]].rename(columns={\n",
        "        \"team_norm\": \"away_team_norm\",\n",
        "        \"ppg\": \"away_ppg\",\n",
        "        \"oppg\": \"away_oppg\",\n",
        "    })\n",
        "\n",
        "    g = g.merge(home_merge, on=\"home_team_norm\", how=\"left\")\n",
        "    g = g.merge(away_merge, on=\"away_team_norm\", how=\"left\")\n",
        "\n",
        "    for c in [\"home_ppg\", \"home_oppg\", \"away_ppg\", \"away_oppg\"]:\n",
        "        g[c] = pd.to_numeric(g[c], errors=\"coerce\")\n",
        "\n",
        "    bad_home = g.loc[g[\"home_ppg\"].isna(), [\"home_team\", \"home_team_clean\", \"home_team_norm\"]].drop_duplicates()\n",
        "    bad_away = g.loc[g[\"away_ppg\"].isna(), [\"away_team\", \"away_team_clean\", \"away_team_norm\"]].drop_duplicates()\n",
        "\n",
        "    if len(bad_home) or len(bad_away):\n",
        "        msg = [\"Team merge failed.\"]\n",
        "        if len(bad_home):\n",
        "            msg += [\"Bad HOME teams:\", bad_home.to_string(index=False)]\n",
        "        if len(bad_away):\n",
        "            msg += [\"Bad AWAY teams:\", bad_away.to_string(index=False)]\n",
        "        msg += [\"Fix ALIASES or team normalization.\"]\n",
        "        raise RuntimeError(\"\\n\".join(msg))\n",
        "\n",
        "    return g\n",
        "\n",
        "g = merge_team_stats(games_df, team_stats)\n",
        "print(\"✔ team_stats merged onto games_df / g\")\n",
        "display(g[[\"home_team\", \"away_team\", \"home_ppg\", \"home_oppg\", \"away_ppg\", \"away_oppg\"]].head(12))\n",
        "\n",
        "# =======================\n",
        "# 6) MANUAL INJURY OVERRIDES\n",
        "# =======================\n",
        "g[\"home_inj_pts\"] = 0.0\n",
        "g[\"away_inj_pts\"] = 0.0\n",
        "\n",
        "if MANUAL_INJURY_OVERRIDES:\n",
        "    g[\"home_inj_pts\"] = g[\"home_team\"].map(MANUAL_INJURY_OVERRIDES).fillna(0.0).astype(float)\n",
        "    g[\"away_inj_pts\"] = g[\"away_team\"].map(MANUAL_INJURY_OVERRIDES).fillna(0.0).astype(float)\n",
        "\n",
        "# =======================\n",
        "# 7) PROJECTIONS\n",
        "# =======================\n",
        "home_pts_base = (W_OFF * g[\"home_ppg\"] + W_DEF * g[\"away_oppg\"]).astype(float)\n",
        "away_pts_base = (W_OFF * g[\"away_ppg\"] + W_DEF * g[\"home_oppg\"]).astype(float)\n",
        "\n",
        "# Pace-compressed raw total in playoff mode\n",
        "g[\"proj_total_raw\"] = ((home_pts_base + away_pts_base) * PACE_MULT).astype(float)\n",
        "\n",
        "# Raw margin + home court + manual injury adjustments\n",
        "g[\"proj_margin_raw\"] = (\n",
        "    (home_pts_base - away_pts_base)\n",
        "    + HOME_COURT_PTS\n",
        "    + (g[\"home_inj_pts\"] - g[\"away_inj_pts\"])\n",
        ").astype(float)\n",
        "\n",
        "# Market margin = -home_spread (home -4.5 => market margin +4.5)\n",
        "g[\"market_margin\"] = (-g[\"home_spread\"]).astype(float)\n",
        "\n",
        "# Anchored projections\n",
        "g[\"proj_total\"] = (\n",
        "    ANCHOR_TOTAL_W * g[\"total_line\"]\n",
        "    + (1.0 - ANCHOR_TOTAL_W) * g[\"proj_total_raw\"]\n",
        ").astype(float)\n",
        "\n",
        "g[\"proj_margin\"] = (\n",
        "    ANCHOR_MARGIN_W * g[\"market_margin\"]\n",
        "    + (1.0 - ANCHOR_MARGIN_W) * g[\"proj_margin_raw\"]\n",
        ").astype(float)\n",
        "\n",
        "g[\"margin_sd\"] = float(BASE_MARGIN_SD)\n",
        "g[\"total_sd\"] = float(BASE_TOTAL_SD)\n",
        "\n",
        "# =======================\n",
        "# 8) MONTE CARLO\n",
        "# =======================\n",
        "np.random.seed(7)\n",
        "\n",
        "marg = g[\"proj_margin\"].to_numpy(dtype=float)\n",
        "tot = g[\"proj_total\"].to_numpy(dtype=float)\n",
        "msd = np.full(len(g), float(BASE_MARGIN_SD))\n",
        "tsd = np.full(len(g), float(BASE_TOTAL_SD))\n",
        "\n",
        "home_cover_thresh = (-g[\"home_spread\"].to_numpy(dtype=float))\n",
        "tot_line = g[\"total_line\"].to_numpy(dtype=float)\n",
        "\n",
        "M = marg[:, None] + msd[:, None] * np.random.randn(len(g), int(N_SIMS))\n",
        "T = tot[:, None] + tsd[:, None] * np.random.randn(len(g), int(N_SIMS))\n",
        "\n",
        "g[\"mc_home_win_prob\"] = (M > 0).mean(axis=1)\n",
        "g[\"mc_home_cover_prob\"] = (M > home_cover_thresh[:, None]).mean(axis=1)\n",
        "g[\"mc_over_prob\"] = (T > tot_line[:, None]).mean(axis=1)\n",
        "\n",
        "# Optional giant-dog dampener in playoff mode\n",
        "if PLAYOFF_MODE:\n",
        "    spread_abs = np.abs(g[\"home_spread\"].to_numpy(dtype=float))\n",
        "    big_spread = spread_abs >= 10.0\n",
        "    dog_damp = np.where(big_spread, 0.015, 0.0)\n",
        "\n",
        "    # Home underdog\n",
        "    mask_home_dog = g[\"home_spread\"].to_numpy(dtype=float) > 0\n",
        "    g.loc[mask_home_dog, \"mc_home_cover_prob\"] = np.maximum(\n",
        "        0.10,\n",
        "        g.loc[mask_home_dog, \"mc_home_cover_prob\"] - dog_damp[mask_home_dog]\n",
        "    )\n",
        "\n",
        "    # Home favorite means away dog\n",
        "    mask_home_fav = g[\"home_spread\"].to_numpy(dtype=float) < 0\n",
        "    g.loc[mask_home_fav, \"mc_home_cover_prob\"] = np.minimum(\n",
        "        0.90,\n",
        "        g.loc[mask_home_fav, \"mc_home_cover_prob\"] + dog_damp[mask_home_fav]\n",
        "    )\n",
        "\n",
        "# =======================\n",
        "# 9) BUILD PLAYS\n",
        "# =======================\n",
        "rows = []\n",
        "for _, r in g.iterrows():\n",
        "    matchup = f\"{r['away_team']} at {r['home_team']}\"\n",
        "\n",
        "    # SPREAD\n",
        "    price_sp = float(r[\"home_spread_price\"])\n",
        "    mp_sp = _imp_prob_amer(price_sp)\n",
        "\n",
        "    p_home = float(r[\"mc_home_cover_prob\"])\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"SPREAD\",\n",
        "        f\"{r['home_team']} {_fmt_spread(r['home_spread'])}\",\n",
        "        price_sp,\n",
        "        p_home,\n",
        "        (p_home - mp_sp),\n",
        "        _amer_from_prob(p_home),\n",
        "        _units_from_halfkelly(_kelly_half(p_home, price_sp)),\n",
        "    ])\n",
        "\n",
        "    p_away = 1.0 - p_home\n",
        "    away_line = float(-r[\"home_spread\"])\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"SPREAD\",\n",
        "        f\"{r['away_team']} {_fmt_spread(away_line)}\",\n",
        "        price_sp,\n",
        "        p_away,\n",
        "        (p_away - mp_sp),\n",
        "        _amer_from_prob(p_away),\n",
        "        _units_from_halfkelly(_kelly_half(p_away, price_sp)),\n",
        "    ])\n",
        "\n",
        "    # TOTAL\n",
        "    price_tot = float(r[\"total_price_used\"])\n",
        "    mp_tot = _imp_prob_amer(price_tot)\n",
        "\n",
        "    p_over = float(r[\"mc_over_prob\"])\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"TOTAL\",\n",
        "        f\"Over {r['total_line']}\",\n",
        "        price_tot,\n",
        "        p_over,\n",
        "        (p_over - mp_tot),\n",
        "        _amer_from_prob(p_over),\n",
        "        _units_from_halfkelly(_kelly_half(p_over, price_tot)),\n",
        "    ])\n",
        "\n",
        "    p_under = 1.0 - p_over\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"TOTAL\",\n",
        "        f\"Under {r['total_line']}\",\n",
        "        price_tot,\n",
        "        p_under,\n",
        "        (p_under - mp_tot),\n",
        "        _amer_from_prob(p_under),\n",
        "        _units_from_halfkelly(_kelly_half(p_under, price_tot)),\n",
        "    ])\n",
        "\n",
        "    # ML\n",
        "    hml = float(r[\"home_ml_price\"])\n",
        "    aml = float(r[\"away_ml_price\"])\n",
        "    p_hw = float(r[\"mc_home_win_prob\"])\n",
        "    p_aw = 1.0 - p_hw\n",
        "\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"ML\",\n",
        "        f\"{r['home_team']} ML\",\n",
        "        hml,\n",
        "        p_hw,\n",
        "        (p_hw - _imp_prob_amer(hml)),\n",
        "        _amer_from_prob(p_hw),\n",
        "        _units_from_halfkelly(_kelly_half(p_hw, hml)),\n",
        "    ])\n",
        "    rows.append([\n",
        "        matchup,\n",
        "        \"ML\",\n",
        "        f\"{r['away_team']} ML\",\n",
        "        aml,\n",
        "        p_aw,\n",
        "        (p_aw - _imp_prob_amer(aml)),\n",
        "        _amer_from_prob(p_aw),\n",
        "        _units_from_halfkelly(_kelly_half(p_aw, aml)),\n",
        "    ])\n",
        "\n",
        "plays = pd.DataFrame(rows, columns=[\n",
        "    \"matchup\", \"market\", \"bet\", \"odds\", \"model_prob\", \"edge\", \"fair_odds\", \"units\"\n",
        "])\n",
        "\n",
        "plays[\"win_ev_score\"] = (0.70 * plays[\"model_prob\"] + 0.30 * plays[\"edge\"]).astype(float)\n",
        "\n",
        "# Keep only modestly positive, reasonably likely plays\n",
        "plays = plays[(plays[\"edge\"] > 0.01) & (plays[\"model_prob\"] > 0.52)].copy()\n",
        "plays = plays.sort_values([\"win_ev_score\", \"edge\"], ascending=False).reset_index(drop=True)\n",
        "\n",
        "# Units\n",
        "plays[\"units_raw\"] = plays[\"units\"].astype(float)\n",
        "plays[\"units\"] = (plays[\"units\"] * float(UNIT_BUMP_MULT)).clip(\n",
        "    lower=float(UNIT_MIN),\n",
        "    upper=float(UNIT_MAX),\n",
        ")\n",
        "\n",
        "# =======================\n",
        "# 10) OUTPUTS\n",
        "# =======================\n",
        "top5 = plays.head(5).copy()\n",
        "top10 = plays.head(10).copy()\n",
        "\n",
        "discord_top5 = _discord(top5, f\"== CDR BETTING | NBA TOP 5 (UPGRADED MC WIN-PRIORITY +EV) ({SLATE_DATE_LOCAL}) ==\")\n",
        "discord_top10 = _discord(top10, f\"== CDR BETTING | NBA TOP 10 (UPGRADED MC WIN-PRIORITY +EV) ({SLATE_DATE_LOCAL}) ==\")\n",
        "\n",
        "print(\"\\n\" + discord_top5 + \"\\n\")\n",
        "\n",
        "top5.to_csv(f\"nba_top5_upgraded_mc_{SLATE_DATE_LOCAL}.csv\", index=False)\n",
        "top10.to_csv(f\"nba_top10_upgraded_mc_{SLATE_DATE_LOCAL}.csv\", index=False)\n",
        "plays.to_csv(f\"nba_full_upgraded_mc_{SLATE_DATE_LOCAL}.csv\", index=False)\n",
        "\n",
        "with open(f\"nba_discord_top5_upgraded_mc_{SLATE_DATE_LOCAL}.txt\", \"w\") as f:\n",
        "    f.write(discord_top5)\n",
